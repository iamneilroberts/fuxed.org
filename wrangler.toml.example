# Copy to wrangler.toml and fill in your own values.
# Create the database first:  wrangler d1 create fuxed-submissions
name = "fuxed"
pages_build_output_dir = "site"
compatibility_date = "2024-11-01"

[[d1_databases]]
binding = "DB"
database_name = "fuxed-submissions"
database_id = "YOUR_D1_DATABASE_ID"
